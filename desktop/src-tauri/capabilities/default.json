[
  {
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "main-capability",
    "description": "Capability for the main Qingputer window.",
    "windows": ["main"],
    "permissions": [
      "core:default",
      "allow-runtime-connection",
      "allow-runtime-request",
      "allow-qingcode-connection",
      "allow-qingcode-request",
      "allow-default-session-config",
      "allow-local-ip-address",
      "allow-qingflow-auth-start",
      "allow-qingflow-auth-snapshot",
      "allow-qingflow-auth-stop",
      "allow-open-external-url"
    ]
  },
  {
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "qingflow-auth-remote",
    "description": "Allow the Qingflow auth window to report token and workspace candidates back to the host.",
    "windows": ["qingflow-auth"],
    "local": false,
    "remote": {
      "urls": [
        "https://qingflow.com/*",
        "https://*.qingflow.com/*",
        "https://cdn-prod.qingflow.com/*",
        "https://file.qingflow.com/*"
      ]
    },
    "permissions": [
      "core:default",
      "allow-qingflow-auth-report"
    ]
  }
]
